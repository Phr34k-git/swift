<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             x:Class="Client.Views.TreasureAppraiseView"
             x:DataType="vm:TreasureAppraiseViewModel"
             Background="{StaticResource Background}">
    <Grid RowDefinitions="Auto,*"
          Margin="34,6,34,34">
        <Border Grid.Row="0"
                Classes="app-card"
                Padding="14">
            <StackPanel Spacing="12">
                <CheckBox IsChecked="{Binding AutoTreasureEnabled}"
                          Content="Auto Treasure"
                          VerticalAlignment="Center"
                          FontFamily="{StaticResource UIFont}"
                          FontSize="13"
                          Foreground="{StaticResource TextPrimary}" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="5">
                        <TextBlock Text="Click Delay (sec)"
                                   FontFamily="{StaticResource UIFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}" />
                        <TextBox Classes="app-input"
                                 Height="36"
                                 Text="{Binding ClickDelaySecondsText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="5">
                        <TextBlock Text="Minimum Multi"
                                   FontFamily="{StaticResource UIFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}" />
                        <TextBox Classes="app-input"
                                 Height="36"
                                 Text="{Binding TargetWeightText}"
                                 PlaceholderText="0.00" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,8,0,0"
              ColumnDefinitions="*">
            <Border Classes="app-card"
                    Height="112"
                    VerticalAlignment="Top"
                    Padding="18,16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Status"
                               FontFamily="{StaticResource UIFont}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}" />
                    <TextBlock Text="{Binding StatusText}"
                               TextWrapping="Wrap"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
