<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             x:Class="Client.Views.AutoAnglerView"
             x:DataType="vm:AutoAnglerViewModel"
             Background="{StaticResource Background}">
    <Grid RowDefinitions="Auto,*"
          Margin="34,6,34,34">
        <Border Grid.Row="0"
                Classes="app-card"
                Padding="14">
            <StackPanel Spacing="12">
                <CheckBox IsChecked="{Binding AutoAnglerEnabled}"
                          Content="Auto Angler"
                          VerticalAlignment="Center"
                          FontFamily="{StaticResource UIFont}"
                          FontSize="13"
                          Foreground="{StaticResource TextPrimary}" />

                <Button Classes="app-secondary"
                        Width="120"
                        Height="34"
                        HorizontalAlignment="Left"
                        Content="Use Cursor"
                        Command="{Binding UseCursorPositionCommand}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,8,0,0"
              ColumnDefinitions="*,*"
              ColumnSpacing="12">
            <Border Grid.Column="0"
                    Classes="app-card"
                    Height="112"
                    VerticalAlignment="Top"
                    Padding="18,16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Current Fish"
                               FontFamily="{StaticResource UIFont}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}" />
                    <TextBlock Text="{Binding CurrentFishText}"
                               TextWrapping="Wrap"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Classes="app-card"
                    Height="112"
                    VerticalAlignment="Top"
                    Padding="18,16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Status"
                               FontFamily="{StaticResource UIFont}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}" />
                    <TextBlock Text="{Binding StatusText}"
                               TextWrapping="Wrap"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
